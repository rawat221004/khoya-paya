# Kumbh Setu environment configuration.
# Copy this file to .env.local and paste your real key:
#   cp .env.example .env.local
#
# The app boots and is fully usable WITHOUT a key — every Claude-powered feature
# (transcript structuring, match explanations, smart search, translation) has a
# deterministic fallback. Add the key to switch those features to real Claude.

# Your Anthropic API key (get one at https://console.anthropic.com/).
# Leave as-is to run in fallback mode.
ANTHROPIC_API_KEY=your_key_here

# Which Claude model the AI features call.
CLAUDE_MODEL=claude-sonnet-4-6

# Secret used to sign session cookies. Change this for any real deployment.
SESSION_SECRET=kumbh-setu-dev-secret-key-change-me-please
